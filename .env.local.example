# Supabase project URL (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service-role key (Project Settings > API) — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Random secret for NextAuth JWT signing — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=

# Base URL of the deployed app (e.g. http://localhost:3000 in dev)
NEXTAUTH_URL=

# Google OAuth client ID (Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=

# Google OAuth client secret (Google Cloud Console > Credentials)
GOOGLE_CLIENT_SECRET=

# Optional AI explanations. Core predictions work without these.
OPENAI_API_KEY=
AI_SLEEP_MODEL=

# Private ChatGPT MCP app. Use the deployed HTTPS origin, with no trailing slash.
# MCP_ALLOWED_EMAIL limits account linking to one Google account (recommended).
MCP_BASE_URL=
MCP_ALLOWED_EMAIL=
SLEEP_TIMEZONE=Asia/Jerusalem

# Web Push. Generate VAPID keys with `npx web-push generate-vapid-keys`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
